# Admin Panel Security - Namecheap Compatible
# ═══════════════════════════════════════════════════

# Force HTTPS for admin panel
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /admin/
    
    # HTTPS redirect (comment out for local development)
    # RewriteCond %{HTTPS} off
    # RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
    
    # Remove index.php from admin root
    RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s/+admin/index\.php[?\s] [NC]
    RewriteRule ^index\.php$ /admin/ [R=301,L]
    
    # Redirect .php URLs to clean URLs
    RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s/+admin/(.*)\.php[\s?] [NC]
    RewriteRule ^(.*)\.php$ /admin/$1 [R=301,L]
    
    # Internally add .php to requests
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME}\.php -f
    RewriteRule ^(.*)$ $1.php [L]
</IfModule>

# Prevent direct access to PHP includes
<Files "includes/*.php">
    Order allow,deny
    Deny from all
</Files>

# Block access to sensitive files
<FilesMatch "\.(bak|old|tmp|log|sql)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Security headers for admin
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "DENY"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Cache-Control "no-cache, no-store, must-revalidate, private"
    Header always set Pragma "no-cache"
    Header always set Expires "0"
</IfModule>

# Prevent directory listing
Options -Indexes

# Optional: IP restriction (uncomment and add your IP)
# <Files "*.php">
#     Order deny,allow
#     Deny from all
#     Allow from YOUR.IP.ADDRESS
# </Files>
